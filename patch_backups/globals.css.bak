@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --sage: #9DB096;
  --sage-dark: #86997D;
  --cream: #FAF6EE;
  --cream-warm: #F3ECDC;
  --copper: #C9A77C;
  --copper-dark: #B08A5E;
  --ink: #2F2A24;
}

html {
  scroll-behavior: smooth;
}
html,
body {
  background-color: var(--cream);
  color: var(--ink);
  font-family: "Lora", Georgia, serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
}

/* Hide scrollbar on horizontal gallery */
.scrollbar-hidden::-webkit-scrollbar { display: none; }
.scrollbar-hidden { -ms-overflow-style: none; scrollbar-width: none; }

/* Subtle ken-burns drift for hero */
@keyframes drift {
  0%   { transform: scale(1.05) translate3d(0,0,0); }
  50%  { transform: scale(1.10) translate3d(-1%, -1%, 0); }
  100% { transform: scale(1.05) translate3d(0,0,0); }
}
.hero-drift { animation: drift 24s ease-in-out infinite; }

/* Polaroid hanging effect */
.pin::before {
  content: "";
  position: absolute;
  top: -10px;
  left: 50%;
  width: 10px;
  height: 10px;
  background: radial-gradient(circle at 30% 30%, #cfcfcf, #6f6f6f 60%, #3a3a3a);
  border-radius: 50%;
  transform: translateX(-50%);
  box-shadow: 0 2px 3px rgba(0,0,0,0.3);
}
.pin::after {
  content: "";
  position: absolute;
  top: -56px;
  left: 50%;
  width: 1px;
  height: 56px;
  background: linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.25));
  transform: translateX(-50%);
}

/* Vintage tint */
.vintage {
  filter: sepia(0.15) saturate(0.9) contrast(1.02);
}

/* Reveal-on-scroll */
.reveal {
  opacity: 0;
  transform: translate3d(0, 24px, 0);
  transition:
    opacity 900ms cubic-bezier(0.22, 0.61, 0.36, 1),
    transform 900ms cubic-bezier(0.22, 0.61, 0.36, 1);
  will-change: opacity, transform;
}
.reveal-in {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; transition: none; }
}

/* Floral divider helper */
.divider-line {
  height: 1px;
  background: linear-gradient(
    to right,
    transparent,
    rgba(157, 176, 150, 0.55) 20%,
    rgba(157, 176, 150, 0.55) 80%,
    transparent
  );
}
